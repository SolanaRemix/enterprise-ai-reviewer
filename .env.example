# API Configuration
# Port for the backend API server
API_PORT=3001
PORT=3001

# Frontend Development Server Port
VITE_DEV_PORT=3000

# API URL (optional - auto-detected if not set)
# VITE_API_URL=http://localhost:3001/api

# API Port for frontend to connect to (used in dynamic URL construction)
VITE_API_PORT=3001

# Gemini AI (for Oracle Audit feature)
# GEMINI_API_KEY=your_api_key_here

# GitHub Token (for PR creation and API access)
# GITHUB_TOKEN=your_token_here

# Repository Brain Access Token (if different from GITHUB_TOKEN)
# REPO_BRAIN_ACCESS_TOKEN=your_token_here

# ==================================================
# Vercel Deployment Configuration
# ==================================================
# These environment variables are required for Vercel deployment
# Update these values in Vercel Dashboard -> Project Settings -> Environment Variables
# after merging this PR

# OpenAI API Key (for AI-powered features)
# OPENAI_API_KEY=sk-your_openai_key_here

# Anthropic API Key (for Claude AI features)
# ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# Google Gemini API Key (for Oracle and analysis features)
# GOOGLE_GEMINI_API_KEY=your_gemini_key_here

# GitHub Personal Access Token (for repository operations)
# Required scopes: repo, workflow, write:packages
# GITHUB_TOKEN=ghp_your_github_token_here

# Node Environment
NODE_ENV=production

# Vercel Analytics (optional)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your_analytics_id_here

# Vercel Project Configuration (auto-set by Vercel)
# VERCEL=1
# VERCEL_ENV=production
# VERCEL_URL=your-project.vercel.app
# VERCEL_GIT_COMMIT_SHA=commit_hash_here

# Sync Strategy Configuration
# SYNC_CONFIG_PATH=.repo-brain/sync-config.json
# FLEET_ROOT=/var/data/repos

# Security Settings
# MAX_LOG_LINES=1000
# SAFE_CONFIG_DIR=.repo-brain

# API Rate Limiting (optional)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

